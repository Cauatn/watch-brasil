    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.4",
    "fastify-type-provider-zod": "^6.1.0",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "29.5.12",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "jest": "29.7.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
