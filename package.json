{
  "name": "watch-brasil",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=api",
    "dev:web": "turbo run dev --filter=web",
    "dev:fe": "docker compose up -d --build api && turbo run dev --filter=web",
    "build": "turbo run build",
    "build:api": "turbo run build --filter=api",
    "build:web": "turbo run build --filter=web",
    "build:project": "yarn install",
    "build:lambda": "yarn workspace api build:lambda",
    "test": "turbo run test --filter=api",
    "test:api": "turbo run test --filter=api",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "docker:up": "docker compose build api && docker compose build web && docker compose up -d",
    "docker:down": "docker compose down",
    "docker:test": "docker compose --profile test run --rm test"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "prettier": "^3.7.4",
    "turbo": "^2.8.20",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@4.6.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "tailwindcss": "^4.2.2"
  }
}
